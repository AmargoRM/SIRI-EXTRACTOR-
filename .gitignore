# Archivos grandes de entrada
# Los insumos geoespaciales en inputs/ se versionan con Git LFS; ver .gitattributes.
# No se ignoran para poder agregarlos con `git add inputs/<archivo>` desde la CLI.

# Resultados generados
outputs/*
checkpoints/*
logs/*

# Mantener carpetas en Git
!outputs/.gitkeep
!checkpoints/.gitkeep
!logs/.gitkeep
!inputs/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/
.env
